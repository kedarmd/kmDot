{
  "layer": "top",
  "position": "top",

  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["custom/kmdot", "custom/clock", "custom/dnd"],
  "modules-right": ["network", "bluetooth", "pulseaudio", "custom/power", "battery"],

  "hyprland/workspaces": {
    "format": "{id}",
    "active-only": false,
    "all-outputs": true,
    "on-click": "activate",
    "sort-by": "number",
    "persistent-workspaces": {
      "*": [1, 2, 3, 4, 5]
    }
  },

  "custom/clock": {
    "exec": "~/.config/waybar/scripts/clock.sh",
    "return-type": "json",
    "interval": 60,
    "tooltip": false
  },

  "custom/kmdot": {
    "format": "’īā kmDot",
    "tooltip": "kmDot dotfiles",
    "on-click": "~/.config/kmdot/rofi/menu/system.sh",
    "tooltip": false
  },

  "custom/dnd": {
    "exec-if": "command -v swaync-client",
    "exec": "~/.config/waybar/scripts/notifications.sh",
    "return-type": "json",
    "interval": 3,
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d",
    "tooltip": true
  },

  "battery": {
    "format": "{icon} {capacity}%",
    "format-charging": "’ā¦ {capacity}%",
    "format-plugged": "’ā¦ {capacity}%",
    "format-alt": "{time} {capacity}%",
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format-icons": [
      "’ēä",
      "’ēā",
      "’ēé",
      "’ēü",
      "’ēĆ"
    ],
    "interval": 3
  },

  "custom/power": {
    "exec": "~/.config/waybar/scripts/power_profile_status.sh",
    "return-type": "json",
    "interval": 60,
    "on-click": "~/.config/waybar/scripts/power_profile_toggle.sh",
    "tooltip": true
  },
  
  "network": {
    "format-wifi": "{icon} {essid}",
    "format-ethernet": "{icon} {ifname}",
    "format-disabled": "{icon} Off",
    "format-disconnected": "{icon} On",
    "format-icons": {
      "wifi": ["¾░ż¤", "¾░żó", "¾░żź", "¾░ż©"],
      "ethernet": "¾░łü",
      "disconnected": "¾░ż»",
      "disabled": "¾░ż«"
    },
    "tooltip-format": "{ifname} via {gwaddr}\n{ipaddr}/{cidr}",
    "interval": 60,
    "on-click": "~/.config/kmdot/rofi/menu/wifi.sh"
  },

  "bluetooth": {
    "format": "¾░é» {status}",
    "format-on": "¾░é» On",
    "format-off": "¾░é▓ Off",
    "format-disabled": "¾░é▓ Off",
    "format-connected": "¾░é» {device_alias}",
    "format-device-preference": [
      "headphones",
      "earbuds",
      "speaker"
    ],
    "tooltip-format": "{controller_alias}\n{device_enumerate}",
    "on-click": "blueman-manager",
    "on-click-right": "bluetoothctl disconnect"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "¾░Ø¤ Muted",
    "tooltip-format": "Volume: {volume}%",
    "scroll-step": 2,
    "on-click": "pamixer -t",
    "format-icons": {
      "default": ["’Ć”", "’Ć¦", "’Ć©"]
    }
  }
}
