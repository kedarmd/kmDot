# Theme and Font

theme = "TokyoNight Night"
font-family = "JetBrainsMono Nerd Font"
font-size = 11

# To hide the top bar

gtk-titlebar = false
window-decoration = false
gtk-tabs-location = bottom
gtk-wide-tabs = false
cursor-style-blink = false
shell-integration-features = no-cursor
shell-integration-features = no-title, no-cursor

# KEYBINDS

# **Keybinds for Tabs**
keybind = ctrl+escape=toggle_tab_overview
keybind = ctrl+w=close_surface

# **Keybinds for Panes and Splits**

keybind = ctrl+shift+o=new_split:down
keybind = ctrl+shift+l=new_split:right
keybind = ctrl+left=goto_split:left
keybind = ctrl+right=goto_split:right
keybind = ctrl+down=goto_split:bottom
keybind = ctrl+up=goto_split:top
